From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Copilot <Copilot@users.noreply.github.com>
Date: Sat Jun 13 14:00:00 2026 +0000
Subject: [PATCH] pyproject: keep flit metadata compatible with Buildroot

Buildroot currently provides flit_core 3.10.1 for flit-based Python
packages. keycard-py requires flit_core >= 3.11 and also uses
newer PEP 621 license metadata that the older backend rejects, causing the
package build to abort before wheel generation.

Relax the build backend requirement to match the bundled flit_core version,
rewrite the project license metadata to the older dict form, and drop the
unsupported license-files key so the package can still be built with the
Buildroot toolchain used by this repository.

---
 pyproject.toml | 4 ++--
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 46d34a4..fe28fd4 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,13 +1,12 @@
 [build-system]
-requires = ["flit_core >=3.11,<4"]
+requires = ["flit_core >=3.10.1,<4"]
 build-backend = "flit_core.buildapi"
 
 [project]
 name = "keycard"
 authors = [{name = "mmlado", email = "developer@mmlado.com"}]
 readme = "README.md"
-license = "MIT"
-license-files = ["LICENSE"]
+license = {file = "LICENSE"}
 dynamic = ["version", "description"]
 requires-python = ">=3.10"
 

