From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Copilot <Copilot@users.noreply.github.com>
Date: Thu, 4 Jun 2026 00:00:00 +0000
Subject: [PATCH] pyproject: keep license metadata compatible with flit

Buildroot currently provides flit_core 3.10.1 for flit-based Python
packages. keycard-py v0.3.0 uses newer PEP 621 metadata that this older
backend rejects, causing the package build to abort before wheel
generation.

Rewrite the project license metadata to the older dict form and drop the
unsupported license-files key so the package can still be built with the
Buildroot toolchain used by this repository.

---
 pyproject.toml | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 1111111..2222222 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -5,8 +5,7 @@ build-backend = "flit_core.buildapi"
 name = "keycard"
 authors = [{name = "mmlado", email = "developer@mmlado.com"}]
 readme = "README.md"
-license = "MIT"
-license-files = ["LICENSE"]
+license = {file = "LICENSE"}
 dynamic = ["version", "description"]
 
 dependencies = [
--
2.39.3
