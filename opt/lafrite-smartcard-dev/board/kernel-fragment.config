# Force built-in for Amlogic GXL hardware required by the initramfs image
# (the arm64 arch default config compiles several of these as modules, which
# cannot be loaded from an initramfs that has no on-disk module tree)
CONFIG_SERIAL_MESON=y
CONFIG_SERIAL_MESON_CONSOLE=y
CONFIG_MMC_MESON_GX=y
CONFIG_STMMAC_ETH=y
CONFIG_STMMAC_PLATFORM=y
CONFIG_DWMAC_MESON=y
CONFIG_PHYLIB=y
CONFIG_MESON_GXL_PHY=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_DWC3=y
CONFIG_USB_STORAGE=y
CONFIG_SPI_MESON_SPICC=y
CONFIG_SPI_SPIDEV=y
CONFIG_HW_RANDOM_MESON=y
